  require_installed "claude" "$claude_bin"
  claude_version=$("$claude_bin" --version 2>/dev/null | head -1 || echo "unknown")
  echo "$(green_bold "✓") claude found at $claude_bin ($claude_version)"

  # ===================================================================
  # Step 2: Seed ~/.claude/settings.json
  # ===================================================================
