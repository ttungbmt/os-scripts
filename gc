# :command.parse_requirements
gc_setup_multi_parse_requirements() {
  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --help | -h)
        long_usage=yes
        gc_setup_multi_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.command_filter
  action="setup multi"

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      # :flag.case
      --skip-shell)

        # :flag.case_no_arg
        args['--skip-shell']=1
        shift
        ;;

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_repeatable
        # :argument.case_repeatable
        escaped="$(printf '%q' "$1")"
        if [[ -z ${args['tools']+x} ]]; then
          args['tools']="$escaped"
        else
          args['tools']="${args['tools']} $escaped"

        fi
        shift

        ;;

    esac
  done
  # :command.required_args_filter
  if [[ -z ${args['tools']+x} ]]; then
    printf "missing required argument: TOOLS\nusage: gc setup multi TOOLS... [OPTIONS]\n" >&2
    exit 1
  fi

}

