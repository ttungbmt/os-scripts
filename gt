# :command.parse_requirements
gt_setup_antidote_parse_requirements() {
  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --help | -h)
        long_usage=yes
        gt_setup_antidote_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.dependencies_filter
  if command -v zsh >/dev/null 2>&1; then
    deps['zsh']="$(command -v zsh | head -n1)"
  else
    printf "missing dependency: zsh\n" >&2
    exit 1
  fi

  if command -v git >/dev/null 2>&1; then
    deps['git']="$(command -v git | head -n1)"
  else
    printf "missing dependency: git\n" >&2
    exit 1
  fi

  # :command.command_filter
  action="setup antidote"

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      # :flag.case
      --skip-plugins)

        # :flag.case_no_arg
        args['--skip-plugins']=1
        shift
        ;;

      # :flag.case
      --skip-zshrc)

        # :flag.case_no_arg
        args['--skip-zshrc']=1
        shift
        ;;

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_simple
        printf "invalid argument: %s\n" "$key" >&2
        exit 1

        ;;

    esac
  done

}

